# Dependencies (always installed in container)
node_modules

# Environment secrets
.env
.env.*
*.env

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# IDEs
.vscode/
.idea/

# Coverage / test artifacts
coverage/
.nyc_output/

# Build output (optional, safe because Docker builds it)
dist/
build/

# Git metadata (never needed in image)
.git
.gitignore

